{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_*",
        "SUPABASE_SERVICE_ROLE_KEY",
        "PAYSTACK_SECRET_KEY",
        "PAYSTACK_WEBHOOK_SECRET",
        "PAYPAL_CLIENT_SECRET",
        "PAYPAL_WEBHOOK_ID",
        "ICAL_TOKEN_SECRET",
        "ICAL_SYNC_WORKER_SECRET",
        "ICAL_SYNC_MIN_INTERVAL_MINUTES",
        "RESEND_API_KEY",
        "EMAIL_FROM_ADDRESS",
        "EMAIL_WORKER_SECRET",
        "EMAIL_VERIFY_SECRET",
        "REVIEW_TOKEN_SECRET",
        "EXTERNAL_REVIEWS_WORKER_SECRET",
        "BANKING_CIPHER_KEY",
        "PAYMENT_CIPHER_KEY",
        "OAUTH_CIPHER_KEY",
        "RATE_LIMIT_SALT",
        "TURNSTILE_SECRET_KEY",
        "GOOGLE_MAPS_API_KEY",
        "GOOGLE_REVIEWS_CLIENT_ID",
        "GOOGLE_REVIEWS_SECRET",
        "FACEBOOK_APP_ID",
        "FACEBOOK_APP_SECRET",
        "ANTHROPIC_API_KEY",
        "ANTHROPIC_MODEL_QUALITY",
        "ANTHROPIC_MODEL_FAST"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "type-check": {}
  }
}
