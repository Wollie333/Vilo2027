# Expo/Metro + pnpm: Metro only resolves modules from top-level node_modules, but
# pnpm keeps transitive deps (e.g. NativeWind's react-native-css-interop runtime,
# which provides react-native-css-interop/jsx-runtime) nested under .pnpm/. Hoist
# the dependency tree so Metro can resolve every (incl. transitive) RN module.
# This is Expo's recommended setting for pnpm monorepos.
node-linker=hoisted
