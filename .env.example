# ─── Vilo — local development environment template ──────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local. NEVER paste real secrets into this file.
# Full reference: ENV_VARS.md

# ─── Supabase ───────────────────────────────────────────────────
# Local: from `supabase start` output
# Cloud: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                  # SERVER-ONLY. Never use NEXT_PUBLIC_ prefix.

# ─── Paystack (ZAR card payments + subscriptions) ───────────────
# Dashboard → Settings → API Keys & Webhooks
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_WEBHOOK_SECRET=                    # Not needed locally; required in staging/prod

# ─── PayPal (international orders + subscriptions) ──────────────
# PayPal Developer → My Apps & Credentials
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=                          # Not needed locally; required in staging/prod
NEXT_PUBLIC_PAYPAL_ENV=sandbox              # sandbox | production

# ─── Email (Resend) ─────────────────────────────────────────────
# Resend Dashboard → API Keys
RESEND_API_KEY=re_
EMAIL_FROM_ADDRESS=noreply@viloplatform.com

# ─── App config ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Vilo

# ─── Maps (Mapbox) ──────────────────────────────────────────────
# Mapbox Dashboard → Tokens — restrict to allowed URLs in production
NEXT_PUBLIC_MAPBOX_TOKEN=pk.

# ─── Monitoring (optional locally; required in staging/prod) ────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
