# ─── Wielo — local development environment template ──────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local. NEVER paste real secrets into this file.
# Full reference: ENV_VARS.md

# ─── Supabase ───────────────────────────────────────────────────
# Local: from `supabase start` output
# Cloud: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                  # SERVER-ONLY. Never use NEXT_PUBLIC_ prefix.

# ─── Paystack (ZAR card payments + subscriptions) ───────────────
# Dashboard → Settings → API Keys & Webhooks
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_WEBHOOK_SECRET=                    # Not needed locally; required in staging/prod

# ─── iCal export tokens (per-listing feed URLs) ─────────────────
# Random 32+ char secret used to derive per-listing iCal feed tokens via
# HMAC. Falls back to SUPABASE_SERVICE_ROLE_KEY when unset. Rotate to
# invalidate every active feed URL at once.
ICAL_TOKEN_SECRET=

# ─── PayPal (international orders + subscriptions) ──────────────
# PayPal Developer → My Apps & Credentials
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=                          # Not needed locally; required in staging/prod
NEXT_PUBLIC_PAYPAL_ENV=sandbox              # sandbox | production

# ─── Email (Resend) ─────────────────────────────────────────────
# Resend Dashboard → API Keys
RESEND_API_KEY=re_
EMAIL_FROM_ADDRESS=Wielo <onboarding@resend.dev>   # production: Wielo <noreply@wieloplatform.com> once the domain verifies

# Shared bearer the email-worker route accepts. Must match the value
# stored in Postgres via `ALTER DATABASE postgres SET
# app.email_worker_secret = '…'` (see migration 20260525000006).
# Generate one with `openssl rand -hex 32`.
EMAIL_WORKER_SECRET=

# ─── App config ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Wielo

# ─── Maps ───────────────────────────────────────────────────────
# Maps are keyless: Leaflet + OpenStreetMap tiles, with Photon/Nominatim
# for geocoding. No token or paid map provider required.

# ─── Monitoring (optional locally; required in staging/prod) ────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── AI (website wizard content generation) ─────────────────────
# Anthropic API key (server-only). The wizard's AI copy step stays INERT until
# this is set — nothing else depends on it. Anthropic Console → API Keys.
ANTHROPIC_API_KEY=
# Optional: pin the Claude model IDs. Defaults track the latest 3.5 aliases;
# set these to the current Sonnet / Haiku IDs from Anthropic's model docs.
ANTHROPIC_MODEL_QUALITY=                    # Sonnet — one-shot "Build my site"
ANTHROPIC_MODEL_FAST=                       # Haiku — per-section regenerate
